	"item": [
		{
			"name": "Auth & Users",
			"item": [
				{
					"name": "Register User",
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"Password123!\",\n  \"firstName\": \"Олександр\",\n  \"lastName\": \"Коваленко\",\n  \"phoneNumber\": \"+380950000000\",\n  \"role\": \"Patient\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/api/users/register",
							"host": ["{{baseUrl}}"],
							"path": ["api", "users", "register"]
						}
					}
				},
				{
					"name": "Login User",
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"Password123!\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/api/users/login",
							"host": ["{{baseUrl}}"],
							"path": ["api", "users", "login"]
						}
					}
				},
				{
					"name": "Upload Avatar (Cloudinary)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "file", "type": "file", "src": "" }
							]
						},
						"url": {
							"raw": "{{baseUrl}}/api/users/{{userId}}/photo",
							"host": ["{{baseUrl}}"],
							"path": ["api", "users", "{{userId}}", "photo"]
						}
					}
				},
				{
					"name": "Get User Profile",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/users/{{userId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "users", "{{userId}}"]
						}
					}
				}
			]
		},
		{
			"name": "Doctor Management",
			"item": [
				{
					"name": "Create Doctor Profile",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"bio\": \"Спеціаліст з когнітивно-поведінкової терапії з 10-річним досвідом.\",\n  \"careerStartDate\": \"2014-05-05T00:00:00Z\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/api/doctors/{{userId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "doctors", "{{userId}}"]
						}
					}
				},
				{
					"name": "Assign Specialization",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"doctorProfileId\": \"{{doctorId}}\",\n  \"name\": \"Психотерапевт\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/api/doctorspecializations/assign",
							"host": ["{{baseUrl}}"],
							"path": ["api", "doctorspecializations", "assign"]
						}
					}
				},
				{
					"name": "Upload Certificate (Cloudinary)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "doctorProfileId", "value": "{{doctorId}}", "type": "text" },
								{ "key": "file", "type": "file", "src": "" }
							]
						},
						"url": {
							"raw": "{{baseUrl}}/api/doctorcertificates/upload",
							"host": ["{{baseUrl}}"],
							"path": ["api", "doctorcertificates", "upload"]
						}
					}
				}
			]
		},
