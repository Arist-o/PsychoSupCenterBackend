		{
			"name": "Appointments & Services",
			"item": [
				{
					"name": "Add Doctor Service",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"serviceName\": \"Індивідуальна консультація\",\n  \"price\": 800.00\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/api/doctorservices?doctorProfileId={{doctorId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "doctorservices"],
							"query": [{ "key": "doctorProfileId", "value": "{{doctorId}}" }]
						}
					}
				},
				{
					"name": "Create Appointment",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"doctorProfileId\": \"{{doctorId}}\",\n  \"patientProfileId\": \"{{patientId}}\",\n  \"doctorServiceId\": \"{{serviceId}}\",\n  \"scheduledAt\": \"2026-06-10T14:00:00Z\",\n  \"durationMinutes\": 60,\n  \"type\": \"Online\",\n  \"notes\": \"Перша сесія\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/api/appointments",
							"host": ["{{baseUrl}}"],
							"path": ["api", "appointments"]
						}
					}
				}
			]
		},
		{
			"name": "Billing",
			"item": [
				{
					"name": "Pay Invoice",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"billingId\": \"{{billingId}}\",\n  \"paymentMethod\": \"Card\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/api/billing/{{billingId}}/pay",
							"host": ["{{baseUrl}}"],
							"path": ["api", "billing", "{{billingId}}", "pay"]
						}
					}
				}
			]
		}
